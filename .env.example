# ══════════════════════════════════════════════════════════════════════════════
# ExamScanify RAG — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in ALL values before running the server or the ingest script.
# ══════════════════════════════════════════════════════════════════════════════


# ── Google Gemini ──────────────────────────────────────────────────────────────
# Used for text embeddings (gemini-embedding-001).
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── Groq ───────────────────────────────────────────────────────────────────────
# Used for the LLM inference (llama-3.1-8b-instant).
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# ── Supabase ───────────────────────────────────────────────────────────────────
# Used for pgvector storage of knowledge-base embeddings.
# Create a free project: https://supabase.com
# Then run sql/schema.sql in the Supabase SQL Editor.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ── Upstash Redis ──────────────────────────────────────────────────────────────
# Used for conversation memory and IP-based rate limiting.
# Free tier available at: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here


# ── LangSmith (optional) ───────────────────────────────────────────────────────
# Enables LangGraph tracing in the LangSmith dashboard.
# Sign up free: https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=false to disable tracing entirely.
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=examscanify-rag


# ── RAG behaviour ──────────────────────────────────────────────────────────────
# How many times the graph will rewrite + retry retrieval before declining.
MAX_RETRIEVAL_RETRIES=2

# Rate limiting: max requests per IP per rolling window.
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_HOURS=1

# Comma-separated list of allowed CORS origins.
# Add your production domain and any local dev URL you need.
CORS_ORIGINS=https://your-domain.com,http://localhost:3000
